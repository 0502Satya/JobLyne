# JobLyne Frontend Environment Config
# Copy this to .env.local and fill in the values

# Backend API URL
# Local development default: http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Node Environment
NODE_ENV=development

# Google OAuth Client ID for Client-side Sign-in
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here

# Shared JWT signing key between frontend and backend (must match Django settings)
# Generate a secure 32-byte hex token: python -c 'import secrets; print(secrets.token_hex(32))' or openssl rand -hex 32
JWT_SECRET=your-32-byte-hex-jwt-secret-here
