# JobLyne Backend Environment Config
# Copy this to .env and fill in the values

# Django Settings
SECRET_KEY=generate_a_secure_random_key_here
# Shared JWT signing key between backend and frontend (must match frontend's JWT_SECRET)
JWT_SECRET=your-32-byte-hex-jwt-secret-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Neon PostgreSQL Database
# Example: postgresql://[user]:[password]@[endpoint]/[dbname]?sslmode=require
DATABASE_URL=
