# JobLyne Backend Environment Config
# Copy this to .env and fill in the values

# Django Settings
# Generate a secure key for production: python -c 'import secrets; print(secrets.token_urlsafe(50))'
SECRET_KEY=your-django-secret-key-here
# Shared JWT signing key between backend and frontend (must match frontend's JWT_SECRET)
# Generate a secure 32-byte hex token: python -c 'import secrets; print(secrets.token_hex(32))' or openssl rand -hex 32
JWT_SECRET=your-32-byte-hex-jwt-secret-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost

# Database (Neon PostgreSQL or local Postgres)
# Format: postgresql://[user]:[password]@[endpoint]/[dbname]?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/joblyne

# Social Auth (Optional but recommended for full testing)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email Configuration (SMTP)
# To enable real email, set EMAIL_BACKEND to django.core.mail.backends.smtp.EmailBackend
# and provide your SMTP details below.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Production CORS — comma-separated list of your deployed frontend origins
CORS_ALLOWED_ORIGINS=https://joblyne.com,https://recruiter.joblyne.com,https://company.joblyne.com

# Redis — required for production rate limiting and caching
REDIS_URL=redis://localhost:6379/0

# LinkedIn OAuth (optional — required for LinkedIn social login)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Production Security Configurations (optional - set values for staging/production)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000
